# ══════════════════════════════════════════
# PCE-Agencia — Variables de Entorno
# ══════════════════════════════════════════
# Copia este archivo como .env y ajusta los valores

PORT=4000

# MongoDB — URI de conexión (dejar en blanco para usar memoria)
MONGO_URI=mongodb://localhost:27017/pce-agencia

# Si es 'true', usa mongodb-memory-server (ideal para demo/deploy rápido)
USE_MEMORY_DB=true

# JWT Secret — cámbialo en producción
JWT_SECRET=pce_agencia_secret_key_change_me
