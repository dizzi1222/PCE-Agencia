# PCE-Agencia — Variables de Entorno
# ══════════════════════════════════════════
# Copia este archivo al directorio server/ como .env y ajusta los valores

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pce_agencia?schema=public"
JWT_SECRET="pce_agencia_secret_key_change_me_in_production"
JWT_REFRESH_SECRET="pce_agencia_refresh_secret_change_me_in_production"
PORT=4000
NODE_ENV=development
